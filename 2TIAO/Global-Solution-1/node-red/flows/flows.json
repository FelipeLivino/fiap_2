  {
    "id": "fn_build_dashboard_metrics",
    "type": "function",
    "z": "tab_astrowater_mqtt",
    "name": "Build /ui metrics",
    "func": "const p = msg.payload || {};\nconst f = p.mlFeatures || {};\nconst numberOrZero = (value) => Number.isFinite(Number(value)) ? Number(value) : 0;\nconst fmt = (value) => Number.isFinite(Number(value)) ? Number(value).toFixed(2) : '-';\n\nconst metricPairs = [\n    ['pH', p.ph],\n    ['Turbidez operacional', p.turbidity],\n    ['Temperatura', p.temperature],\n    ['Hardness', f.Hardness],\n    ['Solids', f.Solids],\n    ['Chloramines', f.Chloramines],\n    ['Sulfate', f.Sulfate],\n    ['Conductivity', f.Conductivity],\n    ['Organic carbon', f.Organic_carbon],\n    ['Trihalomethanes', f.Trihalomethanes],\n    ['Turbidity ML', f.Turbidity]\n];\n\nconst metrics = metricPairs\n    .filter(([, value]) => Number.isFinite(Number(value)))\n    .map(([topic, value]) => ({ topic, payload: Number(value) }));\n\nconst table = [\n    { name: 'deviceId', value: p.deviceId || '-' },\n    { name: 'community', value: p.community || '-' },\n    { name: 'edgeRisk', value: p.edgeRisk || '-' },\n    { name: 'networkSwitch', value: p.networkSwitch || '-' },\n    ...metricPairs.map(([name, value]) => ({ name, value: fmt(value) }))\n];\nconst statusText = `${p.community || 'Comunidade'} | risco ${p.edgeRisk || '-'} | rede ${p.networkSwitch || '-'} | ${new Date().toLocaleTimeString('pt-BR')}`;\nconst status = { payload: { status: statusText, table } };\n\nreturn [\n    metrics,\n    status,\n    { payload: numberOrZero(p.ph) },\n    { payload: numberOrZero(p.turbidity) },\n    { payload: numberOrZero(p.temperature) },\n    { payload: numberOrZero(f.Hardness) },\n    { payload: numberOrZero(f.Solids) },\n    { payload: numberOrZero(f.Chloramines) },\n    { payload: numberOrZero(f.Sulfate) },\n    { payload: numberOrZero(f.Conductivity) },\n    { payload: numberOrZero(f.Organic_carbon) },\n    { payload: numberOrZero(f.Trihalomethanes) },\n    { payload: numberOrZero(f.Turbidity) }\n];",
    "outputs": 13,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 860,
    "y": 300,
    "wires": [
      [
        "ui_chart_all_metrics"
      ],
