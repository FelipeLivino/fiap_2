  {
    "id": "fn_normalize_reading",
    "type": "function",
    "z": "tab_astrowater_mqtt",
    "name": "Normalize backend payload",
    "func": "let reading = msg.payload || {};\n\nif (typeof reading === 'string') {\n    try {\n        reading = JSON.parse(reading);\n    } catch (error) {\n        node.warn(`Payload MQTT nao era JSON valido: ${reading}`);\n        reading = {};\n    }\n}\n\nconst asNumber = (value) => Number.isFinite(Number(value)) ? Number(value) : null;\nconst asNumberOr = (value, fallback) => Number.isFinite(Number(value)) ? Number(value) : fallback;\nconst pick = (...values) => values.find((value) => value !== undefined && value !== null && value !== '');\nconst edgeRisk = String(pick(reading.edgeRisk, reading.risk, 'verde')).toLowerCase();\nconst mlFeatures = {\n    Hardness: asNumber(pick(reading.Hardness, reading.hardness)),\n    Solids: asNumber(pick(reading.Solids, reading.solids)),\n    Chloramines: asNumber(pick(reading.Chloramines, reading.chloramines)),\n    Sulfate: asNumber(pick(reading.Sulfate, reading.sulfate)),\n    Conductivity: asNumber(pick(reading.Conductivity, reading.conductivity)),\n    Organic_carbon: asNumber(pick(reading.Organic_carbon, reading.organicCarbon, reading.organic_carbon)),\n    Trihalomethanes: asNumber(pick(reading.Trihalomethanes, reading.trihalomethanes)),\n    Turbidity: asNumber(pick(reading.Turbidity, reading.mlTurbidity, reading.ml_turbidity))\n};\n\nmsg.payload = {\n    deviceId: pick(reading.deviceId, reading.device_id, 'ASTRO-ESP32-001'),\n    community: pick(reading.community, 'Comunidade Aurora'),\n    ph: asNumberOr(reading.ph, 7),\n    turbidity: asNumberOr(reading.turbidity, 0),\n    temperature: asNumberOr(reading.temperature, 25),\n    ...mlFeatures,\n    edgeRisk,\n    source: pick(reading.source, 'node-red-mqtt-bridge'),\n    networkSwitch: pick(reading.networkSwitch, reading.network_switch, 'ON'),\n    mlFeatures,\n    raw: reading\n};\n\nmsg.headers = { 'Content-Type': 'application/json' };\nmsg.risk = edgeRisk;\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 600,
    "y": 100,
    "wires": [
      [
        "switch_risk_level",
        "http_post_backend",
        "fn_build_dashboard_metrics",
        "debug_normalized_payload"
      ]
    ]
  },
