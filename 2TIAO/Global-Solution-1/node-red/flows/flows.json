    "format": "<div style=\"font-family: Roboto, Arial, sans-serif;\">\n  <h3 style=\"margin: 0 0 12px 0;\">Parametros recebidos no MQTT</h3>\n  <table style=\"width:100%; border-collapse: collapse; font-size: 14px;\">\n    <thead>\n      <tr>\n        <th style=\"text-align:left; padding:6px; border-bottom:1px solid #ddd;\">Parametro</th>\n        <th style=\"text-align:right; padding:6px; border-bottom:1px solid #ddd;\">Valor</th>\n      </tr>\n    </thead>\n    <tbody>\n      <tr ng-repeat=\"item in msg.payload.table\">\n        <td style=\"padding:6px; border-bottom:1px solid #eee;\">{{item.name}}</td>\n        <td style=\"text-align:right; padding:6px; border-bottom:1px solid #eee;\">{{item.value}}</td>\n      </tr>\n    </tbody>\n  </table>\n</div>",
